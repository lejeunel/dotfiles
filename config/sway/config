# Default config for sway
#
# Copy this to ~/.config/sway/config and edit it to your liking.
#
# Read `man 5 sway` for a complete reference.

# styles - set the folder for your theme definition file
set $theme $HOME/.config/sway/themes/dracula

# theme variables
include $theme/definitions

# global variables
include $HOME/.config/sway/definitions

# user variables
include $HOME/.config/sway/definitions.d/*.conf

input type:keyboard {
    xkb_layout "us"
    xkb_variant "qwerty-fr"
}
include $HOME/.config/sway/outputs/*
include $HOME/.config/sway/outputs/*

# enable modes
include $HOME/.config/sway/modes/*

# only enable this if every app you use is compatible with wayland
# xwayland disable

# user config
include $HOME/.config/sway/config.d/*.conf

output * bg $HOME/Pictures/dracula-wallpapers/first-collection/manjaro.png fill
